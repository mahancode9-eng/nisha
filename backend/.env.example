ENVIRONMENT=development
DATABASE_URL=postgresql://nisha:nisha@localhost:5432/nisha
CORS_ORIGINS=http://localhost:3000
UPLOAD_DIR=./uploads
PAYMENT_PROOF_SUBDIR=payment-proofs
MAX_UPLOAD_SIZE_BYTES=5242880
LOW_STOCK_THRESHOLD=5
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-to-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
LOG_LEVEL=INFO

# Notifications — for local uvicorn, set in backend/.env
# For Docker Compose, also set RESEND_API_KEY and EMAIL_* in the repo root .env
EMAIL_PROVIDER=resend
RESEND_API_KEY=re_xxxxxxxxx
EMAIL_FROM=Nisha <noreply@nishanorep.cloudproducts.ir>
FRONTEND_BASE_URL=http://localhost:3000
EMAIL_VERIFICATION_EXPIRE_MINUTES=1440
NOTIFY_WORKER_ENABLED=true
NOTIFY_POLL_INTERVAL_SECONDS=15
