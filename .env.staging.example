# Staging secrets template.
# Copy this file to .env.staging, fill in real values, then run:
#   chmod 600 .env.staging
# .env.staging is git-ignored - NEVER commit it.

# Required
POSTGRES_PASSWORD=change-me-strong-password
JWT_SECRET_KEY=change-me-generate-at-least-64-random-characters
CORS_ORIGINS=https://staging.yourdomain.com
NEXT_PUBLIC_API_URL=https://api-staging.yourdomain.com

# Optional (Sentry)
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=1.0

# Optional (object storage - see docs/object-storage.md)
STORAGE_BACKEND=local
S3_ENDPOINT_URL=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=
S3_PUBLIC_BASE_URL=

# Optional (backups)
BACKUP_INTERVAL_SECONDS=86400
BACKUP_RETENTION_DAYS=3

# Optional (notifications — see docs/notifications.md)
# EMAIL_PROVIDER=resend
# RESEND_API_KEY=re_xxxxxxxxx
# EMAIL_FROM=onboarding@resend.dev
